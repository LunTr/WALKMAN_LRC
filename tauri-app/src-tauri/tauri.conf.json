{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "LRC Processor",
  "version": "1.0.0",
  "identifier": "com.lrcproc.desktop",
  "build": {
    "beforeBuildCommand": "cd .. && go build -buildvcs=false -o lrc-proc-backend.exe .",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "LRC Processor",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
